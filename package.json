{
  "name": "aieditingfooty-discord-music-bot",
  "version": "1.0.0",
  "description": "Discord music bot with slash commands, queueing, and per-guild playback state.",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "register:commands": "tsx src/scripts/registerCommands.ts",
    "check": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@discordjs/voice": "^0.17.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "play-dl": "^1.9.7",
    "pino": "^9.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
